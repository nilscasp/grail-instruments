<svg width="1200" height="1200" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#111625;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0B0D14;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="gold" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#C8A96A;stop-opacity:0.3" />
      <stop offset="100%" style="stop-color:#6D5B3A;stop-opacity:0.3" />
    </linearGradient>
  </defs>
  <rect width="100%" height="100%" fill="url(#bg)"/>
  <circle cx="600" cy="600" r="300" fill="url(#gold)" stroke="#C8A96A" stroke-width="2" opacity="0.5"/>
  <circle cx="600" cy="600" r="200" fill="none" stroke="#C8A96A" stroke-width="1" opacity="0.3"/>
  <circle cx="600" cy="600" r="100" fill="none" stroke="#C8A96A" stroke-width="1" opacity="0.2"/>
  <text x="600" y="620" text-anchor="middle" font-family="Georgia, serif" font-size="48" fill="#C8A96A" opacity="0.6">Instrument</text>
</svg>
